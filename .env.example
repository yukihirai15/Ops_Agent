# OpsAgent — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.

# Required
ANTHROPIC_API_KEY=sk-ant-...

# Required ( If not using ANTHROPIC )
GROQ_API_KEY=gsk_...

# Prometheus (default: Docker Compose service name)
PROMETHEUS_URL=http://prometheus:9090

# Slack (optional — skipped if unset)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Grafana Loki (optional — falls back to Docker logs)
LOKI_URL=

# Agent behaviour
DRY_RUN=false
LOG_LEVEL=info
